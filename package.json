{
  "name": "kiwa-ui",
  "version": "0.0.1",
  "private": true,
  "description": "A shadcn-style component library for Hono-first stacks",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint && pnpm guard:palette-classes && pnpm guard:black-white-classes && pnpm guard:semantic-classes",
    "guard:palette-classes": "node scripts/audit-palette-classes.mjs --fail-on-findings",
    "audit:palette-classes": "node scripts/audit-palette-classes.mjs",
    "guard:black-white-classes": "node scripts/audit-black-white-classes.mjs --fail-on-findings",
    "audit:black-white-classes": "node scripts/audit-black-white-classes.mjs",
    "guard:semantic-classes": "node scripts/audit-semantic-classes.mjs --fail-on-findings",
    "audit:semantic-classes": "node scripts/audit-semantic-classes.mjs"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^20.11.0",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "hono": "^4.0.0",
    "lucide": "^0.575.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
