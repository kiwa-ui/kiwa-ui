    "@tiptap/core": {
      "optional": true
    },
    "@tiptap/pm": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "@tiptap/extension-placeholder": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/dialog.ts src/dropdown.ts src/toast.ts src/clipboard.ts src/theme.ts src/tabs.ts src/accordion.ts src/collapsible.ts src/toggle.ts src/popover.ts src/tooltip.ts src/sheet.ts src/slider.ts src/command.ts src/alert-dialog.ts src/context-menu.ts src/hover-card.ts src/editor.ts src/carousel.ts src/sidebar.ts src/sidebar-mobile.ts src/popover-submenu.ts src/date-picker.ts src/selectable-table.ts src/select.ts src/combobox.ts src/chart-tooltip.ts --format esm --dts",
    "dev": "tsup src/*.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'No linter configured yet'",
    "test": "echo 'No tests configured yet'"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false
